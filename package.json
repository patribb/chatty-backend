{
  "name": "api",
  "version": "1.0.0",
  "description": "API for Chatty App",
  "main": "app.js",
  "scripts": {
    "start": "set NODE_ENV=production&&pm2 start ./build/src/app.js -i 5 --attach --watch | bunyan",
    "stop": "pm2 stop all",
    "delete": "pm2 delete all",
    "dev": "nodemon -r tsconfig-paths/register src/app.ts | bunyan",
    "test": "jest --coverage=true -w=1 --forceExit --detectOpenHandles --watchAll=true",
    "build": "ttsc -p .",
    "seeds:dev": "npx ts-node src/seeds.ts",
    "seeds:prod": "npx ts-node ./build/src/seeds.js"
  },
  "keywords": [],
  "author": "Patricia Garcia",
  "license": "ISC",
