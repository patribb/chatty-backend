    "axios": "^1.2.2",
    "bcryptjs": "^2.4.3",
    "bull": "^4.10.2",
    "bullmq": "^3.5.5",
    "bunyan": "^1.8.15",
    "canvas": "^2.11.0",
    "cloudinary": "^1.33.0",
    "compression": "^1.7.4",
    "cookie-session": "^2.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
