{
  "compilerOptions": {
    "target": "es2016",
    "lib": ["DOM", "ES2016"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "module": "commonjs",
    "rootDir": "src",
    "moduleResolution": "node",
    "baseUrl": ".",
    "resolveJsonModule": true,
    "sourceMap": true,
    "outDir": "./build",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "pretty": true,
    "plugins": [
      { "transform": "typescript-transform-paths" },
      { "transform": "typescript-transform-paths", "afterDeclarations": true }
    ],
    "paths": {
      "@auth/*": ["src/features/auth/*"],
      "@user/*": ["src/features/user/*"],
      "@post/*": ["src/features/post/*"],
      "@reaction/*": ["src/features/reactions/*"],
      "@comment/*": ["src/features/comments/*"],
      "@follower/*": ["src/features/followers/*"],
      "@notification/*": ["src/features/notifications/*"],
      "@image/*": ["src/features/images/*"],
      "@chat/*": ["src/features/chat/*"],
      "@global/*": ["src/shared/global/*"],
      "@service/*": ["src/shared/services/*"],
      "@sockets/*": ["src/shared/sockets/*"],
      "@workers/*": ["src/shared/workers/*"],
      "@root/*": ["src/*"]
    }
  }
}
